<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dev Blog</title>
    <!-- Simple CDN styling to keep things looking clean instantly -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/water.css@2/out/water.css">
</head>
<body>
    <header>
        <nav>
            <a href="/api/posts">🏠 Home</a> | 
            <a href="/api/posts/create">➕ New Post</a> | 
            <% if (typeof currentUser !== 'undefined' && currentUser) { %>
                <span>Signed in as: <strong><%= currentUser.username %> (#<%= currentUser.id %>)</strong></span> |
                <form action="/api/users/logout" method="POST" style="display:inline; margin:0; padding:0;">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit" style="background:none;border:none;color:#1976d2;cursor:pointer;padding:0;font:inherit;">🔓 Logout</button>
                </form>
            <% } else { %>
                <a href="/api/users/login">🔑 Login</a> | 
                <a href="/api/users/register">📝 Register</a>
            <% } %>
        </nav>
    </header>
    <hr>